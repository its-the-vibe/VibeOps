# SlashVibeIssue — sample configuration file
#
# Copy this file to config.yaml and adjust the values for your deployment.
# config.yaml is git-ignored so it will not be committed accidentally.
#
# Secrets (REDIS_PASSWORD, SLACK_BOT_TOKEN) must still be supplied via
# environment variables.  All values below can also be overridden at runtime
# by setting the corresponding environment variable.

# Redis connection
redis_addr: "{{.RedisHost}}:6379"

# Redis pub/sub channels
redis_channel: "{{.SlackCommandRelayChannel}}"
redis_view_submission_channel: "slack-relay-view-submission"
redis_reaction_channel: "{{.SlackRelayReactionAddedChannel}}"
redis_message_action_channel: "slack-relay-message-action"
redis_poppit_output_channel: "{{.PoppitCommandOutputChannel}}"
redis_github_webhook_channel: "github-webhook-issues"
redis_timebomb_channel: "timebomb-messages"

# Redis lists
redis_slackliner_list: "{{.SlackLinerList}}"
redis_poppit_list: "{{.PoppitListName}}"
redis_poppit_builder_list: "{{.PoppitBuilderListName}}"
redis_slack_reactions_list: "slack_reactions"

# SlackLiner HTTP API URL — required for the :brain: reaction to work when
# "Assign to Copilot" and "Sanitise issue on creation" are both selected.
# Set this to the base URL of your SlackLiner service (e.g. http://slackliner:8080).
# TODO: RedisHost is a misnomer at this point since it is used for both Redis and SlackLiner. Consider renaming to something more generic.
slackliner_url: "http://{{.RedisHost}}:{{.SlackLinerPort}}"

# GitHub organisation — required, no default
github_org: "{{.OrgName}}"

# Working directories
working_dir: "{{.BaseDir}}/{{.OrgName}}"
agent_working_dir: "{{.BaseDir}}/{{.OrgName}}/SlashVibeIssue"

# Slack confirmation channel — required, no default
confirmation_channel_id: "{{.IssueSlackChannelID}}"

# Confirmation message TTL (accepts Go duration strings like "48h" or plain seconds)
confirmation_ttl: "240h"

# Maximum number of recent Slack messages to search for a matching issue URL
confirmation_search_limit: 100

# GitHub project settings for automatic issue assignment
project_id: "1"
project_org: "{{.OrgName}}"

# Logging level: DEBUG, INFO, WARN, or ERROR
log_level: "INFO"
