# Renobot configuration example

# GitHub organisation whose Renovate PRs will be summarised.
org: {{.OrgName}}

# Slack channel to post summaries to (name or ID).
channel: "{{.OctoSlackChannelID}}"

# Cron schedule for the summary run (default: 09:00 Mon–Fri).
cron: "0 7 * * *"

# Path to the revamp binary (defaults to "revamp" on PATH).
revamp_path: revamp

redis:
  # Address of the Redis instance used by SlackLiner.
  addr: "{{.RedisHost}}:6379"

  # Redis database number (0 is the default).
  db: 0

  # Key of the SlackLiner message queue list.
  list_key: "{{.SlackLinerList}}"

poppit:
  # Redis list that Poppit reads command payloads from (BLPOP).
  # Must match POPPIT_SERVICE_REDIS_LIST_NAME in your Poppit deployment.
  input_list: "{{.PoppitListName}}"

  # Redis pub/sub channel that Poppit publishes command output to.
  # Must match POPPIT_SERVICE_COMMAND_OUTPUT_CHANNEL in your Poppit deployment.
  output_channel: "{{.PoppitCommandOutputChannel}}"

  # GitHub repository identifier included in Poppit payloads.
  repo: "{{.OrgName}}/Renobot"

  # Git branch reference included in Poppit payloads.
  branch: "refs/heads/main"

  # Working directory Poppit uses when executing revamp commands.
  base_dir: "{{.BaseDir}}/{{.OrgName}}/Renobot"

slack:
  # Redis pub/sub channel that SlackLiner publishes emoji reaction events to.
  # Renobot subscribes to this channel to detect reactions on its posted messages.
  # Defaults to "slack:reactions" if not set.
  reaction_channel: "{{.SlackRelayReactionAddedChannel}}"

  slash_command_channel: "{{.SlackCommandRelayChannel}}"
